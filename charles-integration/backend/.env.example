# Copy this file to .env (cp .env.example .env), then adjust if needed.
# Uses the default `postgres` role with no password (works out of the box on
# Postgres.app and most local Postgres installs). If your Postgres uses a
# password or a different role, update the user[:password] part accordingly.
DATABASE_URL="postgresql://postgres@localhost:5432/kudos_full?schema=public"
PORT=5000
