# ──────────────────────────────────────────────────────────────────────────
# Frontend environment template (Brandon's Cards app)
# Copy this file to `.env` and fill in real values:  cp .env.example .env
# Vite only exposes variables prefixed with VITE_ to the browser.
# ──────────────────────────────────────────────────────────────────────────

# GIPHY API key — required for GIF search in the create-card form.
# Get one at https://developers.giphy.com/ (Create an App → copy the API key).
VITE_GIPHY_API_KEY=YOUR_GIPHY_API_KEY_HERE

# Base URL of the Cards backend (Express on port 5000).
VITE_API_BASE_URL=http://localhost:5000
